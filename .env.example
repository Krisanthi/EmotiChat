# ═══════════════════════════════════════════════
#  EmotiChat — Environment Configuration
# ═══════════════════════════════════════════════

# ── App Settings ──
APP_NAME=Emotion-Aware Chatbot
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Groq LLM (REQUIRED) ──
GROQ_API_KEY=YOUR GROQ API KEY
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.7

# ── AWS ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR AWS ACCESS KEY
AWS_SECRET_ACCESS_KEY=YOUR SECRET ACCESS KEY
AWS_S3_BUCKET=YOUR S3 BUCKET NAME
AWS_REKOGNITION_ENABLED=true

# ── Emotion Detection Models ──
FACE_EMOTION_MODEL=deepface
VOICE_EMOTION_MODEL=librosa
TEXT_EMOTION_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# ── Emotion Fusion Weights (must sum to 1.0) ──
WEIGHT_FACE=0.35
WEIGHT_VOICE=0.30
WEIGHT_TEXT=0.35

# ── Limits ──
MAX_AUDIO_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5
